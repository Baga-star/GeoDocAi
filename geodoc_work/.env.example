APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8001
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:8080
CORS_ALLOW_CREDENTIALS=false
# Optional: set this in shared/staging deployments and also set VITE_API_KEY on frontend.
API_KEY=
RATE_LIMIT_PER_MINUTE=120
ENABLE_DEMO_MODE=false

PARSER_ENGINE=hybrid
VECTOR_BACKEND=local
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=geodoc_ai

# DeepSeek OCR / llm.alem.ai-compatible endpoint
DEEPSEEK_OCR_API_KEY=sk-d6eWV-26WThR44KKbhVSfQ
DEEPSEEK_OCR_URL=https://llm.alem.ai/v1/chat/completions
DEEPSEEK_OCR_MODEL=deepseek-ocr
OCR_MAX_PAGES=30

# Qwen / OpenAI-compatible endpoint
QWEN_BASE_URL=https://llm.alem.ai/v1
QWEN_API_KEY=sk-9GnBFY1LqShBj9IeMNcWJw
QWEN_MODEL=qwen3.6

# Visual Map/Figure Reader / OpenAI-compatible vision endpoint.
# If VISION_API_KEY is replace-me, backend falls back to DEEPSEEK_OCR_API_KEY, then QWEN_API_KEY.
ENABLE_VISUAL_ANALYSIS=true
VISION_API_KEY=sk-d6eWV-26WThR44KKbhVSfQ
VISION_BASE_URL=https://llm.alem.ai/v1
VISION_MODEL=deepseek-ocr
VISION_MAX_PAGES=25
VISION_RENDER_DPI=170

TOP_K=8
SIMILARITY_THRESHOLD=0.05
RERANK=true
